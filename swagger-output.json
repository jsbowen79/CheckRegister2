{
  "openapi": "3.0.0",
  "info": {
    "title": "CheckRegister API",
    "description": "Allows CRUD operations for accounts and transactions with GitHub OAuth authentication.",
    "version": "1.0.0"
  },

  "servers": [
    {
      "url": "https://checkregister2.onrender.com"
    },
    {
      "url": "http://localhost:5000"
    }
  ],

  "components": {
    "securitySchemes": {
      "githubOAuth": {
        "type": "oauth2",
        "description": "GitHub OAuth (session-based authentication handled by backend)",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://github.com/login/oauth/authorize",
            "tokenUrl": "NOT_USED_FOR_SESSION_AUTH",
            "scopes": {
              "user:email": "Access user email"
            }
          }
        }
      }
    }
  },

  "paths": {
    "/account": {
      "get": {
        "description": "Get a list of all accounts.",
        "responses": {
          "200": {
            "description": "Successful response"
          },
          "404": {
            "description": "The database contains no accounts."
          },
          "500": {
            "description": "Database error."
          }
        }
      },

      "post": {
        "description": "Create a new account",

        "security": [
          {
            "githubOAuth": []
          }
        ],

        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": { "type": "number" },
                  "_balance": { "type": "number" },
                  "_pendingBalance": { "type": "number" },
                  "currencyType": { "type": "string" },
                  "accountStatus": { "type": "string" },
                  "createdAt": { "type": "string" },
                  "accountName": { "type": "string" },
                  "type": { "type": "string" },
                  "owner": { "type": "string" },
                  "accountNumber": { "type": "number" }
                }
              }
            }
          }
        },

        "responses": {
          "400": {
            "description": "Missing required account information."
          },
          "401": {
            "description": "Unauthorized. Authentication required."
          },
          "500": {
            "description": "Database error."
          }
        }
      }
    },

    "/account/{accountId}": {
      "get": {
        "description": "Get a single account by id.",

        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "Successful response"
          },
          "404": {
            "description": "Account not found."
          },
          "500": {
            "description": "Database error."
          }
        }
      },

      "put": {
        "description": "Update an account by id",

        "security": [
          {
            "githubOAuth": []
          }
        ],

        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            }
          }
        ],

        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "accountId": { "type": "number" },
                  "_balance": { "type": "number" },
                  "_pendingBalance": { "type": "number" },
                  "currencyType": { "type": "string" },
                  "accountStatus": { "type": "string" },
                  "createdAt": { "type": "string" },
                  "accountName": { "type": "string" },
                  "type": { "type": "string" },
                  "owner": { "type": "string" },
                  "accountNumber": { "type": "number" }
                }
              }
            }
          }
        },

        "responses": {
          "200": {
            "description": "Account updated successfully."
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Account not found."
          },
          "500": {
            "description": "Database error."
          }
        }
      },

      "delete": {
        "description": "Delete an account by id",

        "security": [
          {
            "githubOAuth": []
          }
        ],

        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "Account deleted successfully."
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Account not found."
          },
          "500": {
            "description": "Database error."
          }
        }
      }
    },

    "/transaction": {
      "get": {
        "description": "Get all transactions.",

        "responses": {
          "200": {
            "description": "Successful response"
          },
          "404": {
            "description": "No transactions found."
          },
          "500": {
            "description": "Database error."
          }
        }
      },

      "post": {
        "description": "Create a transaction",

        "security": [
          {
            "githubOAuth": []
          }
        ],

        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": { "type": "number" },
                  "transMedia": { "type": "string" },
                  "transMemo": { "type": "string" },
                  "category": { "type": "string" },
                  "accountId": { "type": "number" },
                  "transType": { "type": "string" },
                  "date": { "type": "string" },
                  "status": { "type": "string" },
                  "endingBalance": { "type": "number" }
                }
              }
            }
          }
        },

        "responses": {
          "200": {
            "description": "Transaction created successfully."
          },
          "401": {
            "description": "Unauthorized."
          },
          "500": {
            "description": "Database error."
          }
        }
      }
    },

    "/transaction/{transactionId}": {
      "get": {
        "description": "Get transaction by id",

        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],

        "responses": {
          "200": {
            "description": "Successful response"
          },
          "404": {
            "description": "Transaction not found."
          },
          "500": {
            "description": "Database error."
          }
        }
      },

      "put": {
        "description": "Update transaction",

        "security": [
          {
            "githubOAuth": []
          }
        ],
        "parameters": [
          {
            "name": "accountId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            }
          }
        ],

        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": { "type": "number" },
                  "transMedia": { "type": "string" },
                  "transMemo": { "type": "string" },
                  "category": { "type": "string" },
                  "accountId": { "type": "number" },
                  "transType": { "type": "string" },
                  "date": { "type": "string" },
                  "status": { "type": "string" },
                  "endingBalance": { "type": "number" }
                }
              }
            }
          }
        },

        "responses": {
          "200": {
            "description": "Transaction updated successfully."
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Transaction not found."
          },
          "500": {
            "description": "Database error."
          }
        }
      },

      "delete": {
        "description": "Delete transaction",

        "security": [
          {
            "githubOAuth": []
          }
        ],

        "responses": {
          "200": {
            "description": "Transaction deleted successfully."
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Transaction not found."
          },
          "500": {
            "description": "Database error."
          }
        }
      }
    },

    "/auth/github": {
      "get": {
        "description": "Redirects user to GitHub OAuth login",
        "responses": {
          "302": {
            "description": "Redirect to GitHub"
          }
        }
      }
    },

    "/auth/github/callback": {
      "get": {
        "description": "OAuth callback from GitHub",
        "responses": {
          "302": {
            "description": "Redirect after successful login"
          },
          "401": {
            "description": "Authentication failed"
          }
        }
      }
    },

    "/auth/logout": {
      "get": {
        "description": "Logs out current session",
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    }
  }
}
